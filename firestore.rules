rules_version = '2';

// ============================================================
//  قواعد حماية Central — عزل كامل بين الشركات (multi-tenant)
//  المبدأ: كل الكتابات عبر Cloud Functions فقط (allow write: if false).
//  القراءات المباشرة من العميل محصورة بنفس الشركة (tenantId).
// ============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // هل المستخدم مسجّل دخول؟
    function isSignedIn() {
      return request.auth != null;
    }

    // هل الوثيقة تخصّ شركة المستخدم؟ (tenantId من الـ token)
    function belongsToTenant() {
      return isSignedIn()
        && request.auth.token.tenantId != null
        && resource.data.tenantId == request.auth.token.tenantId;
    }

    // ===== الوثائق الخاصة (لها قواعد مخصّصة) =====

    // الشركات: المستخدم يقرأ وثيقة شركته فقط (المعرّف = tenantId)
    match /tenants/{tenantId} {
      allow read: if isSignedIn() && request.auth.token.tenantId == tenantId;
      allow write: if false;
    }

    // المستخدمون: يقرأ وثيقته الشخصية أو زملاءه في نفس الشركة
    match /users/{userId} {
      allow read: if isSignedIn() && (
        request.auth.uid == userId ||
        (request.auth.token.tenantId != null && resource.data.tenantId == request.auth.token.tenantId)
      );
      allow write: if false;
    }

    // مالكو المنصة: كل واحد يقرأ وثيقته فقط (التحقق الفعلي في الدوال)
    match /platformOwners/{ownerId} {
      allow read: if isSignedIn() && request.auth.uid == ownerId;
      allow write: if false;
    }

    // إعدادات المنصة (الأسعار): أي مستخدم مسجّل يقرأ — يحتاجها بناء النظام
    match /platformConfig/{docId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // ===== كل المجموعات الأخرى: قراءة لنفس الشركة فقط، الكتابة عبر الدوال =====
    match /{collection}/{docId} {
      allow read: if belongsToTenant();
      allow write: if false;
    }
  }
}
